<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex flex-col justify-center text-center">
    <h1 class="font-bold text-4xl text-slate-100">Your orders, <%= current_user.firstname %> <%= current_user.lastname %>
      <i class="fa-solid fa-seedling"></i> </h1>
  </div>

  <div class="mb-5"></div>
  <div class="mb-5"></div>

  <div class="grid grid-cols-2 gap-4 m-auto justify-center">
    <% @cart.each do |cart_item| %>
      <div class="max-w-sm bg-stone-900 rounded-lg dark:bg-stone-800 dark:bg-stone-800 ">
        <div class="bg-stone-600 rounded-tl-lg hover:rounded-tr-3xl">
          <div class="p-3 gif"></div>
        </div>
        <div class="px-5 pb-5">
          <a href="#">
            <h5 class="text-xl font-semibold tracking-tight text-gray-900 dark:text-white"> <%= cart_item.name %></h5>
            <h7 class="text-l font-semibold tracking-tight text-gray-900 dark:text-white"> <%= cart_item.description %></h7>
          </a>

          <div class="mt-3">
            <span class="text-3xl font-bold text-gray-900 dark:text-white"> <%= cart_item.price %>$</span>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="p-3">
    <p class="font-bold text-slate-100"> It'll be delivered soon. </p>
  </div>

</div>
