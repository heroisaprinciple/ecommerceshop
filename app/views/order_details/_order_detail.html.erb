<div id="<%= dom_id order_detail %>">
  <% if action_name != "show" %>
    <%= link_to "Show this order detail", order_detail, class: "rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <%= link_to 'Edit this order detail', edit_order_detail_path(order_detail), class: "rounded-lg py-3 ml-2 px-5 bg-gray-100 inline-block font-medium" %>
    <hr class="mt-6">
  <% end %>
</div>
