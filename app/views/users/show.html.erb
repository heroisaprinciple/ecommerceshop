<div class="mx-auto md:w-2/3 w-full flex">
  <div class="mx-auto">
    <% if notice.present? %>
      <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
    <% end %>

    <%= render partial: 'user' %>

    <div class="flex flex-col justify-center text-center">
      <h1 class="font-bold text-4xl text-slate-100">Hello, friend! </h1>
    </div>

    <% unless @cart.empty? %>
      <div class="max-w-sm bg-stone-900 rounded-lg dark:bg-stone-800 dark:bg-stone-800 text-white">
        <p> Would you like to see the items in your cart? </p>
      </div>
    <% end %>

  </div>
</div>
